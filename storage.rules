rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Listing photos: public read, write only by the authenticated owner of the folder
    match /listings/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // General fallback rules - restrict writes by default outside listings
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Block all other writes by default
    }
  }
}
